-- Helper function to generate an ESP Section config easily
local function SetupEspSection(tab, name, side)
    local esp = tab:Section(name, side)
    
    local features = {"name", "health", "distance", "weapons", "boxes", "tracers"}
    for _, feature in ipairs(features) do
        esp:Toggle({
            Name = feature:sub(1,1):upper() .. feature:sub(2) .. " ESP",
            Default = false,
            Callback = function(state)
                print(name .. " " .. feature .. " toggled:", state)
            end
        })
        esp:ColorPicker({
            Name = feature:sub(1,1):upper() .. feature:sub(2) .. " Color",
            Default = Color3.fromRGB(255, 255, 255),
            Callback = function(color)
                print(name .. " " .. feature .. " color set to:", color)
            end
        })
    end
    
    esp:Dropdown({
        Name = "Tracers Placement",
        Options = {"Top", "Middle", "Bottom"},
        Default = "Bottom",
        Callback = function(placement)
            print(name .. " tracers placement set to:", placement)
        end
    })
    
    return esp
end

