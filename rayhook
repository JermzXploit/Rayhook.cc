local function isMouseOverEnemy()
    local mousePos = UIS:GetMouseLocation()
    local ray = Camera:ViewportPointToRay(mousePos.X, mousePos.Y)
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {Players.LocalPlayer.Character}
    params.FilterType = Enum.RaycastFilterType.Blacklist
    local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, params)
    
    if not result then
        return false
    end
    local character = result.Instance:FindFirstAncestorOfClass("Model")
    if not character then
        return false
    end
    local spawned = workspace:FindFirstChild("Spawned")
    local playerCharacters = spawned and spawned:FindFirstChild("PlayerCharacters")
    if playerCharacters and character:IsDescendantOf(playerCharacters) then
        if character ~= Players.LocalPlayer.Character then
            if library.flags["trigger_team_check"] then
                local player = Players:GetPlayerFromCharacter(character)
                if player and player.Team == Players.LocalPlayer.Team then
                    return false
                end
            end
            return true
        end
    end
    
    return false
end
local function fireClick()
    local mousePos = UIS:GetMouseLocation()
    virtualInputManager:SendMouseButtonEvent(mousePos.X, mousePos.Y, 0, true, game, 0)
    virtualInputManager:SendMouseButtonEvent(mousePos.X, mousePos.Y, 0, false, game, 0)
end
