                local Obj = { GetText = function() return Input.Text end, SetText = function(t) Input.Text = t end, Set = function(t) Input.Text = t end }
                Library.Flags[opts.Flag or opts.Name] = Obj
                return Obj
            end

            function Section:ColorPicker(opts)
                local h, s, v = 0, 1, 1
