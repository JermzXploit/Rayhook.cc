-- Custom JSON Serialization for complex configuration values
function library:getConfig()
    local serialized = {}
    for key, val in pairs(library.flags) do
        -- Skip configuration inputs themselves
        if key ~= "config_name_text_box" and key ~= "config_name_list" then
            if type(val) == "table" then
                if val.Color and typeof(val.Color) == "Color3" then
                    -- Color Picker structures
                    serialized[key] = {
                        __type = "ColorPicker",
                        color = val.Color:ToHex(),
                        transparency = val.Transparency or 0
                    }
                elseif val.key then
                    -- Keybind structures
                    serialized[key] = {
                        __type = "Keybind",
                        key = tostring(val.key),
                        active = val.active,
                        mode = val.mode
                    }
                else
                    serialized[key] = val
                end
            else
                serialized[key] = val
            end
        end
    end
    return HttpService:JSONEncode(serialized)
end
function library:loadConfig(jsonStr)
    local success, data = pcall(function() return HttpService:JSONDecode(jsonStr) end)
    if not success or type(data) ~= "table" then return end
    
    for key, val in pairs(data) do
        local setter = library.config_flags[key]
        if setter then
            pcall(function()
                if type(val) == "table" and val.__type == "ColorPicker" then
                    setter(Color3.fromHex(val.color), val.transparency)
                elseif type(val) == "table" and val.__type == "Keybind" then
                    setter(val)
                else
                    setter(val)
                end
            end)
        end
    end
end
-- Custom cross-executor config scanning helper
function library:configListUpdate() 
    if not config_holder then return end 
    local list = {}
    pcall(function()
        for _, file in ipairs(listfiles("Rayhook.cc/configs")) do
            -- Extract file name without path and extension
            local name = file:match("([^/\\]+)%.cfg$")
            if name then
                table.insert(list, name)
            end
        end
    end)
    config_holder.refresh_options(list)
end 
