local function NewQuad(thickness, color)
    local q = Drawing.new("Quad")
    q.Visible = false
    q.PointA = Vector2.new(0, 0)
    q.PointB = Vector2.new(0, 0)
    q.PointC = Vector2.new(0, 0)
    q.PointD = Vector2.new(0, 0)
    q.Color = color
    q.Filled = false
    q.Thickness = thickness
    q.Transparency = 1
    return q
end
local function NewLine(thickness, color)
    local l = Drawing.new("Line")
    l.Visible = false
    l.From = Vector2.new(0, 0)
    l.To = Vector2.new(0, 0)
    l.Color = color
    l.Thickness = thickness
    l.Transparency = 1
    return l
end
local function NewText(size, color)
    local t = Drawing.new("Text")
    t.Visible = false
    t.Text = ""
    t.Size = size
    t.Color = color
    t.Center = true
    t.Outline = true
    t.OutlineColor = Color3.fromRGB(0, 0, 0)
    t.Transparency = 1
    return t
end
local function setQuadSize(quad, cx, cy, dy)
    quad.PointA = Vector2.new(cx + dy, cy - dy * 2)
    quad.PointB = Vector2.new(cx - dy, cy - dy * 2)
    quad.PointC = Vector2.new(cx - dy, cy + dy * 2)
    quad.PointD = Vector2.new(cx + dy, cy + dy * 2)
end
