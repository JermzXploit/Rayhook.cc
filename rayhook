local espData = {}
local function ESP(plr)
    if espData[plr] then
        if espData[plr].connection then espData[plr].connection:Disconnect() end
        for _, obj in pairs(espData[plr].drawings) do
            pcall(function() obj:Remove() end)
        end
    end
    local drawings = {
        blackBox    = NewQuad(2, Color3.new(0, 0, 0)),
        box         = NewQuad(1, Color3.new(1, 1, 1)),
        healthbar   = NewLine(3, Color3.new(0, 0, 0)),
        greenhealth = NewLine(1.5, Color3.new(0, 1, 0)),
        name        = NewText(13, Color3.new(1, 1, 1)),
        distance    = NewText(13, Color3.new(1, 1, 1)),
        tracer      = NewLine(1, Color3.new(1, 1, 1)),
    }
    local conn
    conn = RunService.RenderStepped:Connect(function()
        local spawned = workspace:FindFirstChild("Spawned")
        local player_chars = spawned and spawned:FindFirstChild("PlayerCharacters")
        local char = player_chars and player_chars:FindFirstChild(plr.Name) or plr.Character
        if not char then
            for _, obj in pairs(drawings) do obj.Visible = false end
            if not Players:FindFirstChild(plr.Name) then
                conn:Disconnect()
            end
            return
        end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not (hrp and head and hum and hum.Health > 0) then
            for _, obj in pairs(drawings) do obj.Visible = false end
            return
        end
        local humPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        if not onScreen then
            for _, obj in pairs(drawings) do obj.Visible = false end
            return
        end
        local headScreen = Camera:WorldToViewportPoint(head.Position)
        local distY = math.clamp(
            (Vector2.new(headScreen.X, headScreen.Y) - Vector2.new(humPos.X, humPos.Y)).Magnitude,
            2, math.huge
        )
        -- Box ESP
        if library.flags["esp_boxes_enabled"] then
            local boxColor = library.flags["esp_boxes_color"]
            local color = Color3.fromRGB(255, 255, 255)
            if boxColor then
                if type(boxColor) == "table" and boxColor.Color then
                    color = boxColor.Color
                elseif typeof(boxColor) == "Color3" then
                    color = boxColor
                end
            end
            drawings.box.Color = color
            setQuadSize(drawings.box, humPos.X, humPos.Y, distY)
            setQuadSize(drawings.blackBox, humPos.X, humPos.Y, distY)
            drawings.box.Visible = true
            drawings.blackBox.Visible = true
        else
            drawings.box.Visible = false
            drawings.blackBox.Visible = false
        end
        -- Health ESP
        if library.flags["esp_health_enabled"] then
            local barHeight = distY * 4
            local healthFrac = hum.Health / hum.MaxHealth
            local healthOffset = healthFrac * barHeight
            drawings.healthbar.From = Vector2.new(humPos.X - distY - 5, humPos.Y + distY * 2)
            drawings.healthbar.To   = Vector2.new(humPos.X - distY - 5, humPos.Y - distY * 2)
            drawings.greenhealth.From = Vector2.new(humPos.X - distY - 5, humPos.Y + distY * 2)
            drawings.greenhealth.To   = Vector2.new(humPos.X - distY - 5, humPos.Y + distY * 2 - healthOffset)
            local healthColor = library.flags["esp_health_color"]
            if healthColor then
                local customCol = Color3.fromRGB(0, 255, 0)
                if type(healthColor) == "table" and healthColor.Color then
                    customCol = healthColor.Color
                elseif typeof(healthColor) == "Color3" then
                    customCol = healthColor
                end
                drawings.greenhealth.Color = customCol
            else
                local red = Color3.fromRGB(255, 0, 0)
                local green = Color3.fromRGB(0, 255, 0)
                drawings.greenhealth.Color = red:Lerp(green, healthFrac)
            end
            drawings.healthbar.Visible = true
            drawings.greenhealth.Visible = true
        else
            drawings.healthbar.Visible = false
            drawings.blackBox.Visible = false
        end
        -- Name ESP
        if library.flags["esp_name_enabled"] then
            local nameColor = library.flags["esp_name_color"]
            local color = Color3.fromRGB(255, 255, 255)
            if nameColor then
                if type(nameColor) == "table" and nameColor.Color then
                    color = nameColor.Color
                elseif typeof(nameColor) == "Color3" then
                    color = nameColor
                end
            end
            drawings.name.Color = color
            drawings.name.Text = plr.Name
            drawings.name.Position = Vector2.new(humPos.X, humPos.Y - distY * 2 - 16)
            drawings.name.Visible = true
        else
            drawings.name.Visible = false
        end
        -- Distance ESP
        if library.flags["esp_distance_enabled"] then
            local distColor = library.flags["esp_distance_color"]
            local color = Color3.fromRGB(255, 255, 255)
            if distColor then
                if type(distColor) == "table" and distColor.Color then
                    color = distColor.Color
                elseif typeof(distColor) == "Color3" then
                    color = distColor
                end
            end
            local localChar = Players.LocalPlayer.Character
            local localHrp = localChar and localChar:FindFirstChild("HumanoidRootPart")
            local distanceVal = 0
            if localHrp and hrp then
                distanceVal = math.round((localHrp.Position - hrp.Position).Magnitude)
            end
            drawings.distance.Color = color
            drawings.distance.Text = tostring(distanceVal) .. "m"
            drawings.distance.Position = Vector2.new(humPos.X, humPos.Y + distY * 2 + 4)
            drawings.distance.Visible = true
        else
            drawings.distance.Visible = false
        end
        -- Tracer ESP
        if library.flags["esp_tracers_enabled"] then
            local tracerColor = library.flags["esp_tracers_color"]
            local color = Color3.fromRGB(255, 255, 255)
            if tracerColor then
                if type(tracerColor) == "table" and tracerColor.Color then
                    color = tracerColor.Color
                elseif typeof(tracerColor) == "Color3" then
                    color = tracerColor
                end
            end
            local placement = library.flags["esp_tracer_placement"] or "Bottom"
            local screenWidth = Camera.ViewportSize.X
            local screenHeight = Camera.ViewportSize.Y
            local origin = Vector2.new(screenWidth / 2, screenHeight)
            if placement == "Top" then
                origin = Vector2.new(screenWidth / 2, 0)
            elseif placement == "Middle" then
                origin = Vector2.new(screenWidth / 2, screenHeight / 2)
            end
            drawings.tracer.Color = color
            drawings.tracer.From = origin
            drawings.tracer.To = Vector2.new(headScreen.X, headScreen.Y)
            drawings.tracer.Visible = true
        else
            drawings.tracer.Visible = false
        end
    end)
    espData[plr] = { connection = conn, drawings = drawings }
end
