                local function update(input)
                    local pct = math.clamp((input.Position.X - SliderBack.AbsolutePosition.X) / SliderBack.AbsoluteSize.X, 0, 1)
                    local rawVal = min + (max - min) * pct
                    if decimals > 0 then
                        local mult = 10^decimals
                        val = math.floor(rawVal * mult + 0.5) / mult
                    else
                        val = math.floor(rawVal)
                    end
                    SliderFill.Size = UDim2.new(pct, 0, 1, 0)
                    Value.Text = string.format("%." .. decimals .. "f", val)
                    opts.Callback(val)
                end
                
