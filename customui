        local LeftColumn = Create("Frame", { Name = "Left", Size = UDim2.new(0.5, -8, 1, -12), Position = UDim2.new(0, 6, 0, 6), BackgroundTransparency = 1, AutomaticSize = Enum.AutomaticSize.Y, ZIndex = 3, Parent = TabPage, ClipsDescendants = false })
