local ConfigDropdown
local function GetConfigs()
    local tbl = {}
    local success, err = pcall(function()
        if isfolder and isfolder("Rayhook") then
            if listfiles then
                for _, v in pairs(listfiles("Rayhook")) do
                    if v:sub(-5) == ".json" then
                        table.insert(tbl, v:split("\\")[2]:split(".json")[1] or v)
                    end
                end
            end
        elseif makefolder then
            makefolder("Rayhook")
        end
    end)
    if #tbl == 0 then table.insert(tbl, "None") end
    return tbl
end

ConfigDropdown = ConfigSection:Dropdown({
    Name = "Select Config",
    Options = GetConfigs(),
    Default = "None"
})

ConfigSection:Button({
    Name = "Load Config",
    Callback = function()
        local cfg = ConfigDropdown:Get()
        if cfg and cfg ~= "None" then
            pcall(function()
                if isfile("Rayhook/" .. cfg .. ".json") then
                    local data = HttpService:JSONDecode(readfile("Rayhook/" .. cfg .. ".json"))
                    -- Apply flag configs here if desired
                    Library:Notification({Text = "Loaded: " .. cfg, Duration = 3})
                end
            end)
        end
    end
})

ConfigSection:Button({
    Name = "Save Config",
    Callback = function()
        local name = ConfigTextBox:GetText()
        if name ~= "" then
            pcall(function()
                if writefile then
                    writefile("Rayhook/" .. name .. ".json", HttpService:JSONEncode({}))
                    ConfigDropdown:Update(GetConfigs())
                    Library:Notification({Text = "Saved: " .. name, Duration = 3})
                end
            end)
        end
    end
})

