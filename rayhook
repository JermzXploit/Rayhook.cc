local last_shot = 0
RunService.RenderStepped:Connect(function()
    -- Render & Position FOV Circle in the middle of the screen
    if fov_circle_gui then
        if library.flags["fov_circle_enabled"] and library.flags["aimbot_enabled"] then
            fov_circle_gui.Visible = true
            local radius = library.flags["fov_size_value"] or 100
            fov_circle_gui.Size = UDim2.new(0, radius * 2, 0, radius * 2)
            fov_circle_gui.Position = UDim2.new(0.5, 0, 0.5, 0)
            
            local custom_color = library.flags["fov_color"]
            if custom_color then
                if type(custom_color) == "table" and custom_color.Color then
                    fov_stroke.Color = custom_color.Color
                elseif typeof(custom_color) == "Color3" then
                    fov_stroke.Color = custom_color
                end
            else
                fov_stroke.Color = Color3.fromRGB(255, 255, 255)
            end
        else
            fov_circle_gui.Visible = false
        end
    end
    -- Target tracking and Camera lock execution
    if library.flags["aimbot_enabled"] and getgenv().aimbot_active then
        getgenv().target_part = get_closest_player()
        local target = getgenv().target_part
        if target and library.flags["aimbot_type"] == "Camera" then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
        end
    else
        getgenv().target_part = nil
    end
    -- Draw Snapline
    if getgenv().snap_line_drawing then
        local enabled = library.flags["snapline_enabled"]
        local target = getgenv().target_part
        if not target and library.flags["aimbot_enabled"] then
            target = get_closest_player()
        end
        if enabled and target then
            local screen_pos, on_screen = Camera:WorldToViewportPoint(target.Position)
            if on_screen then
                local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                getgenv().snap_line_drawing.From = center
                getgenv().snap_line_drawing.To = Vector2.new(screen_pos.X, screen_pos.Y)
                
                local col = library.flags["snapline_color"]
                local color = Color3.fromRGB(255, 255, 255)
                if col then
                    if type(col) == "table" and col.Color then
                        color = col.Color
                    elseif typeof(col) == "Color3" then
                        color = col
                    end
                end
                getgenv().snap_line_drawing.Color = color
                getgenv().snap_line_drawing.Visible = true
            else
                getgenv().snap_line_drawing.Visible = false
            end
        else
            getgenv().snap_line_drawing.Visible = false
        end
    end
    -- Triggerbot execution loop
    if library.flags["triggerbot_enabled"] and getgenv().triggerbot_active then
        local now = os.clock()
        local delay_val = library.flags["trigger_delay_value"] or 0.1
        if now - last_shot >= delay_val then
            if isMouseOverEnemy() then
                fireClick()
                last_shot = now
            end
        end
    end
end)
