local function get_closest_player()
    local closest_part = nil
    local shortest_distance = math.huge
    
    local spawned = workspace:FindFirstChild("Spawned")
    if not spawned then return nil end
    local player_chars = spawned:FindFirstChild("PlayerCharacters")
    if not player_chars then return nil end
    
    local screen_center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    local selected_parts = library.flags["hit_parts_selected"] or {"Head"}
    if type(selected_parts) ~= "table" then
        selected_parts = {selected_parts}
    end
    
    for _, char in ipairs(player_chars:GetChildren()) do
        if char:IsA("Model") and char.Name ~= Players.LocalPlayer.Name then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                for _, part_name in ipairs(selected_parts) do
                    local part = char:FindFirstChild(part_name)
                    if part and part:IsA("BasePart") then
                        local screen_pos, on_screen = Camera:WorldToViewportPoint(part.Position)
                        if on_screen then
                            local distance = (Vector2.new(screen_pos.X, screen_pos.Y) - screen_center).Magnitude
                            
                            local fov_max = library.flags["fov_size_value"] or 100
                            if not library.flags["fov_circle_enabled"] or distance <= fov_max then
                                if distance < shortest_distance then
                                    shortest_distance = distance
                                    closest_part = part
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    return closest_part
end
